    "RpcError": {
      "additionalProperties": false,
      "properties": {
        "code": {
          "title": "Code",
          "type": "string"
        },
        "data": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Data"
        },
        "message": {
          "title": "Message",
          "type": "string"
        }
      },
      "required": [
        "code",
        "message"
      ],
      "title": "RpcError",
      "type": "object"
    },
    "RpcEvent": {
      "additionalProperties": false,
      "properties": {
        "data": {
          "title": "Data"
        },
        "event": {
          "title": "Event",
          "type": "string"
        },
        "type": {
          "const": "event",
          "default": "event",
          "title": "Type",
          "type": "string"
        },
        "v": {
          "const": 2,
          "default": 2,
          "title": "V",
          "type": "integer"
        }
      },
      "required": [
        "event",
        "data"
      ],
      "title": "RpcEvent",
      "type": "object"
    },
    "RpcRequest": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Id",
          "type": "string"
        },
        "method": {
          "pattern": "^[a-z][A-Za-z0-9]*(\\.[a-z][A-Za-z0-9]*)+$",
          "title": "Method",
          "type": "string"
        },
        "params": {
          "additionalProperties": true,
          "title": "Params",
          "type": "object"
        },
        "type": {
          "const": "request",
          "title": "Type",
          "type": "string"
        },
        "v": {
          "const": 2,
          "title": "V",
          "type": "integer"
        }
      },
      "required": [
        "v",
        "type",
        "id",
        "method"
      ],
      "title": "RpcRequest",
      "type": "object"
    },
    "RpcResponse": {
      "additionalProperties": false,
      "properties": {
        "error": {
          "anyOf": [
            {
              "$ref": "#/$defs/RpcError"
            },
            {
              "type": "null"
            }
          ],
          "default": null
