{
  "$defs": {
    "ArtifactRef": {
      "additionalProperties": false,
      "properties": {
        "artifactId": {
          "title": "Artifactid",
          "type": "string"
        },
        "createdAt": {
          "format": "date-time",
          "title": "Createdat",
          "type": "string"
        },
        "height": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Height"
        },
        "kind": {
          "title": "Kind",
          "type": "string"
        },
        "mimeType": {
          "title": "Mimetype",
          "type": "string"
        },
        "runId": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Runid"
        },
        "sessionId": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Sessionid"
        },
        "sha256": {
          "title": "Sha256",
          "type": "string"
        },
        "size": {
          "title": "Size",
          "type": "integer"
        },
        "width": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Width"
        }
      },
      "required": [
        "artifactId",
        "kind",
        "mimeType",
        "size",
        "sha256",
        "createdAt"
      ],
      "title": "ArtifactRef",
      "type": "object"
    },
    "DebugEvent": {
      "additionalProperties": false,
      "properties": {
        "artifactRefs": {
          "items": {
            "$ref": "#/$defs/ArtifactRef"
          },
          "title": "Artifactrefs",
          "type": "array"
        },
        "kind": {
          "title": "Kind",
          "type": "string"
        },
        "parentSeq": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Parentseq"
        },
        "payload": {
          "additionalProperties": true,
          "title": "Payload",
          "type": "object"
        },
        "phase": {
          "title": "Phase",
          "type": "string"
        },
        "runId": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Runid"
        },
        "seq": {
          "default": 0,
          "title": "Seq",
          "type": "integer"
        },
        "sessionId": {
          "title": "Sessionid",
          "type": "string"
        },
        "source": {
          "enum": [
            "maafw",
            "localbridge",
            "mpe"
          ],
          "title": "Source",
          "type": "string"
        },
        "status": {
          "title": "Status",
          "type": "string"
        },
        "timestamp": {
          "format": "date-time",
          "title": "Timestamp",
          "type": "string"
        }
      },
      "required": [
        "sessionId",
        "source",
        "kind",
        "phase",
        "status"
      ],
      "title": "DebugEvent",
      "type": "object"
    },
    "DocumentOpenResult": {
      "additionalProperties": false,
      "properties": {
        "artifact": {
          "anyOf": [
            {
              "$ref": "#/$defs/ArtifactRef"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "content": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Content"
        },
        "editable": {
          "default": false,
          "title": "Editable",
          "type": "boolean"
        },
        "encoding": {
          "anyOf": [
            {
              "const": "utf-8",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Encoding"
        },
        "kind": {
          "enum": [
            "pipeline",
            "interface",
            "json",
            "text",
            "markdown",
            "image",
            "binary"
          ],
          "title": "Kind",
          "type": "string"
        },
        "language": {
          "default": "",
          "title": "Language",
          "type": "string"
        },
        "mimeType": {
          "default": "application/octet-stream",
          "title": "Mimetype",
          "type": "string"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "path": {
          "title": "Path",
          "type": "string"
        },
        "previewable": {
          "default": true,
          "title": "Previewable",
          "type": "boolean"
        },
        "readOnlyReason": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Readonlyreason"
        },
        "revision": {
          "title": "Revision",
          "type": "string"
        },
        "role": {
          "anyOf": [
            {
              "enum": [
                "default_pipeline",
                "mpe_config"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Role"
        },
        "size": {
          "default": 0,
          "title": "Size",
          "type": "integer"
        }
      },
      "required": [
        "path",
        "name",
        "kind",
        "revision"
      ],
      "title": "DocumentOpenResult",
      "type": "object"
    },
    "DocumentSaveResult": {
      "additionalProperties": false,
