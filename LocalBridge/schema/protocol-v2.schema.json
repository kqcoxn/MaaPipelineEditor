  "$id": "https://mpe.codax.site/schema/localbridge-v2.json",
  "properties": {
    "artifact": {
      "$ref": "#/$defs/ArtifactRef"
    },
    "debug_event": {
      "$ref": "#/$defs/DebugEvent"
    },
    "document_open_result": {
      "$ref": "#/$defs/DocumentOpenResult"
    },
    "document_save_result": {
      "$ref": "#/$defs/DocumentSaveResult"
    },
    "message": {
      "discriminator": {
        "mapping": {
          "event": "#/$defs/RpcEvent",
          "request": "#/$defs/RpcRequest",
          "response": "#/$defs/RpcResponse"
        },
        "propertyName": "type"
      },
      "oneOf": [
        {
          "$ref": "#/$defs/RpcRequest"
        },
        {
          "$ref": "#/$defs/RpcResponse"
        },
        {
          "$ref": "#/$defs/RpcEvent"
        }
      ],
      "title": "Message"
    },
    "workspace_documents": {
      "$ref": "#/$defs/WorkspaceDocumentsPayload"
    },
    "workspace_tree": {
      "$ref": "#/$defs/WorkspaceTreePayload"
    }
  },
  "required": [
    "message",
    "artifact",
    "debug_event",
    "workspace_tree",
    "workspace_documents",
    "document_open_result",
    "document_save_result"
