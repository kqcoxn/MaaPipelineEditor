        "id": {
          "title": "Id",
          "type": "string"
        },
        "result": {
          "anyOf": [
            {},
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Result"
        },
        "type": {
          "const": "response",
          "default": "response",
          "title": "Type",
          "type": "string"
        },
        "v": {
          "const": 2,
          "default": 2,
          "title": "V",
          "type": "integer"
        }
      },
      "required": [
        "id"
      ],
      "title": "RpcResponse",
      "type": "object"
    },
