---
import type { ShowcaseItem } from "@/content/landing";

type Props = {
  items: ShowcaseItem[];
};

const { items } = Astro.props;

const accentMap = {
  blue: {
    chip: "bg-blue-50 text-blue-700",
    glow: "from-blue-500/30 to-cyan-400/0",
    dot: "bg-blue-500",
  },
  mint: {
    chip: "bg-emerald-50 text-emerald-700",
    glow: "from-emerald-500/30 to-teal-400/0",
    dot: "bg-emerald-500",
  },
  orange: {
    chip: "bg-orange-50 text-orange-700",
    glow: "from-orange-500/30 to-amber-400/0",
    dot: "bg-orange-500",
  },
  rose: {
    chip: "bg-rose-50 text-rose-700",
    glow: "from-rose-500/30 to-pink-400/0",
    dot: "bg-rose-500",
  },
} as const;
---

<div class="grid gap-5 md:grid-cols-2">
  {
    items.map((item, index) => {
      const accent = accentMap[item.accent];

      return (
        <article
          class="group overflow-hidden rounded-[30px] border border-white/70 bg-white/90 shadow-[0_22px_80px_rgba(20,32,51,0.08)] transition-all duration-500 ease-out hover:-mt-2 hover:mb-2 hover:shadow-[0_32px_100px_rgba(20,32,51,0.14)]"
          data-reveal="up"
          style={`--reveal-delay: ${index * 90}ms;`}
        >
          <div
            class={`relative h-60 overflow-hidden bg-linear-to-br ${accent.glow}`}
          >
            <div class="absolute inset-x-6 top-6 rounded-[24px] border border-white/80 bg-white/80 p-4 shadow-[0_20px_50px_rgba(20,32,51,0.08)] backdrop-blur">
              <div class="flex items-center justify-between">
                <div class="flex items-center gap-2">
                  <span class={`h-3 w-3 rounded-full ${accent.dot}`} />
                  <span class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-500">
                    Placeholder Scene
                  </span>
                </div>
                <span
                  class={`rounded-full px-3 py-1 text-xs font-semibold ${accent.chip}`}
                >
                  首版占位
                </span>
              </div>
              <div class="mt-4 grid gap-3">
                <div class="h-3 w-2/3 rounded-full bg-slate-200" />
                <div class="h-3 w-full rounded-full bg-slate-100" />
                <div class="h-3 w-5/6 rounded-full bg-slate-100" />
              </div>
            </div>
            <div class="absolute inset-x-8 bottom-8 grid gap-3 sm:grid-cols-2">
              <div class="rounded-[22px] border border-white/80 bg-white/80 p-4 backdrop-blur">
                <div class="h-3 w-24 rounded-full bg-slate-200" />
                <div class="mt-3 h-2 w-full rounded-full bg-slate-100" />
                <div class="mt-2 h-2 w-4/5 rounded-full bg-slate-100" />
              </div>
              <div class="rounded-[22px] border border-white/80 bg-white/80 p-4 backdrop-blur">
                <div class="flex items-center gap-2">
                  <span class={`h-2.5 w-2.5 rounded-full ${accent.dot}`} />
                  <div class="h-3 w-20 rounded-full bg-slate-200" />
                </div>
                <div class="mt-3 h-2 w-full rounded-full bg-slate-100" />
                <div class="mt-2 h-2 w-3/4 rounded-full bg-slate-100" />
              </div>
            </div>
          </div>

          <div class="p-6">
            <div class="flex flex-wrap gap-2">
              {item.tags.map((tag) => (
                <span
                  class={`rounded-full px-3 py-1 text-xs font-semibold ${accent.chip}`}
                >
                  {tag}
                </span>
              ))}
            </div>
            <h3 class="mt-4 text-xl font-semibold text-slate-950">
              {item.title}
            </h3>
            <p class="mt-3 text-sm leading-7 text-slate-600">{item.summary}</p>
            <p class="mt-3 text-sm leading-7 text-slate-500">{item.detail}</p>
            <a
              href={item.href}
              class="mt-5 inline-flex items-center gap-2 text-sm font-semibold text-slate-900 transition hover:text-blue-700"
            >
              {item.ctaLabel}
              <span aria-hidden="true">→</span>
            </a>
          </div>
        </article>
      );
    })
  }
</div>
