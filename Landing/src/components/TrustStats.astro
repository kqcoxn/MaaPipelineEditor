---
import type { StatItem } from "@/content/landing";

type Props = {
  items: StatItem[];
};

const { items } = Astro.props;

const metrics = items.filter((item): item is Extract<StatItem, { kind: "metric" }> => item.kind === "metric");
const ecosystems = items.filter(
  (item): item is Extract<StatItem, { kind: "ecosystem" }> => item.kind === "ecosystem",
);

const accentMap = {
  blue: "text-blue-700 bg-blue-50 border-blue-100",
  mint: "text-emerald-700 bg-emerald-50 border-emerald-100",
  orange: "text-orange-700 bg-orange-50 border-orange-100",
  rose: "text-rose-700 bg-rose-50 border-rose-100",
} as const;
---

<section id="ecosystem" class="section-spacing px-4 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-7xl">
    <div class="mx-auto max-w-3xl text-center">
      <span class="section-chip">生态与可信度</span>
      <h2 class="mt-6 text-balance text-3xl font-semibold text-slate-950 sm:text-4xl">
        用真实边界建立信任，再把生态入口组织清楚
      </h2>
      <p class="mt-4 text-pretty text-base leading-7 text-slate-600">
        首版先不用夸张指标。我们用真实的进入成本、协议兼容与生态入口告诉用户，MPE 是一块可持续演进的流程工作台。
      </p>
    </div>

    <div class="mt-10 grid gap-5 md:grid-cols-2 xl:grid-cols-4">
      {
        metrics.map((item) => (
          <article class="rounded-[30px] border border-white/70 bg-white/90 p-6 shadow-[0_18px_60px_rgba(20,32,51,0.08)]">
            <span class={`inline-flex rounded-full border px-3 py-1 text-xs font-semibold ${accentMap[item.accent]}`}>
              {item.value}
            </span>
            <h3 class="mt-5 text-lg font-semibold text-slate-950">{item.label}</h3>
            <p class="mt-3 text-sm leading-7 text-slate-600">{item.note}</p>
          </article>
        ))
      }
    </div>

    <div class="mt-8 rounded-[34px] border border-white/70 bg-white/88 p-6 shadow-[0_24px_80px_rgba(20,32,51,0.08)] backdrop-blur sm:p-8">
      <div class="flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-500">生态入口</p>
          <h3 class="mt-2 text-2xl font-semibold text-slate-950">把 LocalBridge、Extremer 与 MCP 放到同一张入口地图里</h3>
        </div>
        <p class="max-w-xl text-sm leading-7 text-slate-600">
          Header 和 Hero 负责说明价值，这里负责告诉用户后续能往哪里延展。首版全部使用文案与占位壳层，不阻塞工程交付。
        </p>
      </div>

      <div class="mt-6 grid gap-4 lg:grid-cols-3">
        {
          ecosystems.map((item) => (
            <a
              href={item.href}
              class="group rounded-[28px] border border-slate-200 bg-slate-50/80 p-5 transition hover:-translate-y-1 hover:border-slate-300 hover:bg-white"
            >
              <span class={`inline-flex rounded-full border px-3 py-1 text-xs font-semibold ${accentMap[item.accent]}`}>
                {item.value}
              </span>
              <h4 class="mt-4 text-lg font-semibold text-slate-950">{item.label}</h4>
              <p class="mt-3 text-sm leading-7 text-slate-600">{item.note}</p>
              <span class="mt-4 inline-flex items-center gap-2 text-sm font-semibold text-slate-900 transition group-hover:text-blue-700">
                查看入口
                <span aria-hidden="true">→</span>
              </span>
            </a>
          ))
        }
      </div>
    </div>
  </div>
</section>
