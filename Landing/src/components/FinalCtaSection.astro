---
import type { ActionLink } from "@/content/landing";

type Props = {
  primaryAction: ActionLink;
  secondaryAction: ActionLink;
};

const { primaryAction, secondaryAction } = Astro.props;
---

<section class="section-spacing px-4 pb-24 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-7xl">
    <div
      class="relative overflow-hidden rounded-[40px] border border-white/70 bg-[linear-gradient(135deg,rgba(79,134,255,0.12),rgba(67,199,184,0.08),rgba(255,155,98,0.12))] px-6 py-10 shadow-[0_24px_80px_rgba(20,32,51,0.1)] sm:px-10 sm:py-14"
      data-reveal="zoom"
    >
      <div
        class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(79,134,255,0.24),transparent_32%),radial-gradient(circle_at_bottom_right,rgba(255,155,98,0.2),transparent_28%)] opacity-80"
      >
      </div>
      <div class="relative mx-auto max-w-3xl text-center">
        <span class="section-chip">开始使用</span>
        <h2
          class="mt-6 text-balance text-3xl font-semibold text-slate-950 sm:text-5xl"
        >
          MaaPipelineEditor
        </h2>
        <p class="mt-4 text-pretty text-base leading-7 text-slate-600">
          基于 react-flow 的 MaaFramework Pipeline 工作流式可视化编辑器
          <br />即刻使用，连接你的想法！
        </p>
        <div
          class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row"
        >
          <a
            href={primaryAction.href}
            class="inline-flex min-h-12 items-center justify-center rounded-full bg-[linear-gradient(135deg,#4F86FF_0%,#3CC7B8_100%)] px-6 py-3 text-sm font-semibold text-white shadow-[0_18px_40px_rgba(79,134,255,0.26)] transition hover:brightness-105"
          >
            {primaryAction.label}
          </a>
          <a
            href={secondaryAction.href}
            class="inline-flex min-h-12 items-center justify-center rounded-full border border-slate-200 bg-white/85 px-6 py-3 text-sm font-semibold text-slate-700 transition hover:border-slate-300 hover:text-slate-950"
          >
            {secondaryAction.label}
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
