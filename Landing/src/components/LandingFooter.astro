---
import type { FooterColumn } from "@/content/landing";

type Props = {
  columns: FooterColumn[];
};

const { columns } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="border-t border-slate-200/80 px-4 py-10 sm:px-6 lg:px-8">
  <div class="mx-auto grid max-w-7xl gap-10 lg:grid-cols-[1.3fr_2fr]">
    <div data-reveal="left">
      <div class="flex items-center gap-3">
        <img
          src="/logo.png"
          alt=""
          width="48"
          height="48"
          class="h-12 w-12 shrink-0 rounded-[16px] border border-white/70 bg-white object-cover shadow-[0_12px_28px_rgba(20,32,51,0.12)]"
        />
        <div>
          <p class="text-base font-semibold text-slate-950">
            MaaPipelineEditor
          </p>
          <p class="text-sm text-slate-500">Pipeline Visual Workspace</p>
        </div>
      </div>
      <p class="mt-4 max-w-md text-sm leading-7 text-slate-600">
        告别手调千行 JSON！用拖拽+配置的方式，高效构建、调试、分享您的 MFW
        自动化流程
      </p>
    </div>

    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
      {
        columns.map((column, index) => (
          <section
            data-reveal="up"
            style={`--reveal-delay: ${80 + index * 70}ms;`}
          >
            <h2 class="text-sm font-semibold uppercase tracking-[0.18em] text-slate-500">
              {column.title}
            </h2>
            <ul class="mt-4 space-y-3">
              {column.links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    target={link.external ? "_blank" : undefined}
                    rel={link.external ? "noreferrer" : undefined}
                    class="text-sm text-slate-600 transition hover:text-slate-950"
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </section>
        ))
      }
    </div>
  </div>

  <div
    class="mx-auto mt-10 flex max-w-7xl flex-col gap-2 border-t border-slate-200/80 pt-6 text-sm text-slate-500 sm:flex-row sm:items-center sm:justify-between"
    data-reveal="up"
    style="--reveal-delay: 180ms;"
  >
    <p>© {year} MaaPipelineEditor / codax. All rights reserved.</p>
    <p>
      Landing MVP focuses on structure, conversion, and independent delivery.
    </p>
  </div>
</footer>
