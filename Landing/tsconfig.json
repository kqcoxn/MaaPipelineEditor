{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "baseUrl": ".",
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "paths": {
      "@/*": [
        "src/*"
      ]
    },
    "types": [
      "@types/node"
    ]
  },
  "include": [
    ".astro/types.d.ts",
    "**/*"
  ]
}
