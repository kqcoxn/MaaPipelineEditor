{
  "name": "maa-pipeline-editor-repository",
  "private": true,
  "packageManager": "yarn@1.22.22",
  "scripts": {
    "editor:install": "yarn --cwd Editor install --frozen-lockfile",
    "icon": "yarn --cwd Editor icon",
    "dev": "yarn --cwd Editor dev",
    "build": "yarn --cwd Editor build",
    "build-past": "yarn --cwd Editor build-past",
    "lint": "yarn --cwd Editor lint",
    "preview": "yarn --cwd Editor preview",
    "server": "yarn --cwd LocalBridge server",
    "doc": "yarn --cwd DocumentStation dev",
    "landing": "yarn --cwd Landing dev",
    "landing:build": "yarn --cwd Landing build",
    "landing:test": "yarn --cwd Landing verify",
    "landing:preview": "yarn --cwd Landing preview",
    "migrate": "node scripts/development/migrate-version.mjs",
    "proto": "node scripts/development/proto-version.mjs",
    "release": "git tag -a v1.7.5 -m \"v1.7.5\" && git push origin v1.7.5",
    "retag": "git tag -d v1.7.5"
  }
}
